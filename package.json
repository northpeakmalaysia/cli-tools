{
  "name": "@swarmai/cli-tools",
  "version": "0.1.0",
  "description": "Wraps installed CLIs as agent tools — Linux/macOS/Windows/Termux (Android)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "swarmai-package.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/bundle.mjs",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@swarmai/plugin-sdk": ">=0.5.0",
    "@swarmai/shared": ">=0.5.0"
  },
  "peerDependenciesMeta": {
    "@swarmai/plugin-sdk": {
      "optional": false
    },
    "@swarmai/shared": {
      "optional": false
    }
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "zod": "^3.23.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "NorthPeak Malaysia <ops@northpeak.app>",
  "repository": {
    "type": "git",
    "url": "https://github.com/northpeakmalaysia/cli-tools"
  },
  "homepage": "https://hub.northpeak.app",
  "engines": {
    "node": ">=22.0.0"
  }
}
